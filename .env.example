# Nons Shelf rides the shared nons SSO session: the access_token cookie set by
# nons-server on the parent domain (.nonsapp.com). There is no separate login.
#
# This is a Next.js app: browser-exposed vars use the NEXT_PUBLIC_ prefix and are
# inlined at BUILD time, so they must be set in the deploy/build environment.

# Nons Shelf API base URL (nons-library-server). A different origin in prod, so
# set it to the backend's TLS subdomain (empty = same origin).
NEXT_PUBLIC_LIBRARY_API_URL=https://shelfapi.nonsapp.com

# nons-server base URL (the identity provider) — used for session refresh/logout
# and any credentialed nonsFetch() call (friendships, cover uploads, etc).
# Must be the Go backend's own host, NOT nonsapp.com (the Vercel app) — Vercel's
# /api/:path* rewrite is a same-origin proxy for nonsapp.com's own pages and
# doesn't preserve CORS for a different calling origin like shelf.nonsapp.com,
# so credentialed cross-origin requests through it get silently CORS-blocked.
# api.nonsapp.com is the real backend, with CORS configured for shelf.nonsapp.com.
NEXT_PUBLIC_NONS_API_URL=https://api.nonsapp.com

# The nons login page; users are sent here with ?redirect= and come back after.
NEXT_PUBLIC_NONS_LOGIN_URL=https://nonsapp.com

# Google Books API key for ISBN autofill (avoids the shared keyless 429).
NEXT_PUBLIC_GOOGLE_BOOKS_KEY=

# Server-side base URL the Next.js server uses to fetch public catalog data for
# the SSR /b and /m pages (no "same origin" on the server). Usually the same
# backend as NEXT_PUBLIC_LIBRARY_API_URL.
LIBRARY_SERVER_URL=https://shelfapi.nonsapp.com

# Canonical/OpenGraph origin for the SSR pages (link previews, <link canonical>).
NEXT_PUBLIC_SITE_URL=https://shelf.nonsapp.com

# Local dev example:
# NEXT_PUBLIC_LIBRARY_API_URL=http://localhost:8081
# NEXT_PUBLIC_NONS_API_URL=http://localhost:8080
# NEXT_PUBLIC_NONS_LOGIN_URL=http://localhost:3000
# LIBRARY_SERVER_URL=http://localhost:8081
# NEXT_PUBLIC_SITE_URL=http://localhost:5173
