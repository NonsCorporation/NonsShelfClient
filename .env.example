# Nons Shelf rides the shared nons SSO session: the access_token cookie set by
# nons-server on the parent domain (.nonsapp.com). There is no separate login.

# Nons Shelf API base URL (nons-library-server). On GitHub Pages the API is a
# different origin, so set this to the backend's TLS subdomain in production.
VITE_LIBRARY_API_URL=https://shelfapi.nonsapp.com

# nons-server base URL (the identity provider) — used for session refresh/logout.
VITE_NONS_API_URL=https://nonsapp.com

# The nons login page; users are sent here with ?redirect= and come back after.
VITE_NONS_LOGIN_URL=https://nonsapp.com

# Local dev example:
# VITE_LIBRARY_API_URL=http://localhost:8081
# VITE_NONS_API_URL=http://localhost:8080
# VITE_NONS_LOGIN_URL=http://localhost:3000
